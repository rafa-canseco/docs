{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "maple",
  "appearance": {
    "default": "dark"
  },
  "name": "b1nary",
  "colors": {
    "primary": "#22D3EE",
    "light": "#22D3EE",
    "dark": "#06B6D4"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Learn",
        "groups": [
          {
            "group": "Getting Started",
            "pages": [
              "index",
              "how-it-works",
              "options-101"
            ]
          },
          {
            "group": "Strategies",
            "pages": [
              "strategies",
              "range",
              "positions",
              "faq"
            ]
          }
        ]
      },
      {
        "tab": "Developers",
        "groups": [
          {
            "group": "Build on b1nary",
            "pages": [
              "developers/getting-started",
              "developers/environments",
              "developers/api-reference",
              "developers/smart-contracts",
              "developers/integration-guide"
            ]
          }
        ]
      },
      {
        "tab": "Market Making",
        "groups": [
          {
            "group": "Market Making",
            "pages": [
              "market-making/overview",
              "market-making/pricing",
              "market-making/hedging",
              "market-making/integration",
              "market-making/risk-controls"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "App",
          "href": "https://b1nary.app",
          "icon": "arrow-up-right-from-square"
        },
        {
          "anchor": "Testnet",
          "href": "https://staging.b1nary.app",
          "icon": "flask-vial"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "App",
        "href": "https://b1nary.app"
      }
    ]
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "footer": {
    "socials": {
      "x": "https://x.com/b1naryapp"
    }
  }
}
